async function makeApiCall() {
  try {
    const response = await fetch("/api/attendance/list", {
      method: "GET",
      headers: {
        "Content-Type": "application/json"
      }
    });

    // 1. Check if the response is empty or if it's an error code (like 404/500)
    if (!response.ok) {
      const errorText = await response.text(); // Read as plain text first to see what went wrong
      console.error("Server returned an error page/text instead of JSON:", errorText);
      return;
    }

    // 2. Safely parse only when you know it's a valid 200 OK stream
    const data = await response.json();
    return data;

  } catch (error) {
    console.error("Caught error parsing JSON:", error);
  }
}
