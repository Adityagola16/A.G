async function getAttendanceHistory() {
  try {
    // 1. Fire the request over to your Express route
    const response = await fetch("/api/attendance/list");
    
    // 2. Turn the raw JSON stream from res.json() into an iterable array/object
    const data = await response.json();
    
    console.log("Your parsed attendance data:", data);
    return data;
  } catch (error) {
    console.error("Failed to parse JSON response:", error);
  }
}
